<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:C4iSytemsMobApp.Models"
             xmlns:helpers="clr-namespace:C4iSytemsMobApp.Helpers"
             x:Class="C4iSytemsMobApp.RosterPage"
             Title="Roster"
             BackgroundColor="{AppThemeBinding Light=White, Dark=Black}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:BooleanToArrowConverter x:Key="BooleanToArrowConverter" />
            <helpers:ShiftStatusToGradientConverter x:Key="ShiftStatusToGradientConverter" />
            <helpers:HolidayToColorConverter x:Key="HolidayToColorConverter" />
            <helpers:NotNullToBooleanConverter x:Key="NotNullToBooleanConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto"
          Padding="10,5,10,10"
          RowSpacing="10">

        <!-- Header Section: Title Left, Home Icon Right -->
        <Grid ColumnDefinitions="*,Auto"
              VerticalOptions="Center"
              Grid.Row="0">
            <Label Text="My Roster"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Start"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <ImageButton Source="home.png"
                         Clicked="OnHomeClicked"
                         HeightRequest="30"
                         WidthRequest="30"
                         BackgroundColor="Transparent"
                         HorizontalOptions="End"
                         VerticalOptions="Center"
                         Grid.Column="1" />
        </Grid>

        <!-- Week Navigation Controls -->
        <Frame Grid.Row="1" 
               Padding="5" 
               CornerRadius="10" 
               HasShadow="False"
               BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#1E1E1E}">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                <Button Grid.Column="0"
                        Text="&#xf053;"
                        FontFamily="FontAwesome"
                        Clicked="OnPreviousWeekClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        FontSize="16" />

                <Label Grid.Column="1"
                       x:Name="WeekRangeLabel"
                       Text="Loading week..."
                       FontSize="16"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <Button Grid.Column="2"
                        Text="&#xf054;"
                        FontFamily="FontAwesome"
                        Clicked="OnNextWeekClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        FontSize="16" />
            </Grid>
        </Frame>

        <!-- Roster Content -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout x:Name="RosterContainer" Spacing="5">
                
                <Label x:Name="NoRosterLabel"
                       Text="No roster exist"
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Margin="0,50,0,0"
                       IsVisible="False"
                       TextColor="Gray" />

                <VerticalStackLayout x:Name="DaysList" BindableLayout.ItemsSource="{Binding Days}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:RosterDay">
                            <VerticalStackLayout Spacing="0" Margin="0,0,0,8">
                                
                                <!-- Day Header -->
                                <Frame Padding="10,8" 
                                       CornerRadius="4" 
                                       HasShadow="False"
                                       BackgroundColor="{AppThemeBinding Light=#512bd4, Dark=#ac99ea}">
                                    <Frame.Triggers>
                                        <DataTrigger TargetType="Frame" Binding="{Binding IsPublicHoliday}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#FFF9C4" />
                                        </DataTrigger>
                                    </Frame.Triggers>
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDayHeaderTapped" CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="{Binding DayName}" 
                                                   TextColor="{AppThemeBinding Light=White, Dark=Black}" 
                                                   FontAttributes="Bold" 
                                                   FontSize="16" />
                                            <Label Text=" (Holiday)" 
                                                   TextColor="Red" 
                                                   FontSize="12" 
                                                   VerticalOptions="Center" 
                                                   IsVisible="{Binding IsPublicHoliday}" />
                                        </HorizontalStackLayout>
                                        <Label Grid.Column="1" 
                                               Text="{Binding IsExpanded, Converter={StaticResource BooleanToArrowConverter}}" 
                                               TextColor="{AppThemeBinding Light=White, Dark=Black}" 
                                               FontFamily="FontAwesome" 
                                               FontSize="14" />
                                    </Grid>
                                </Frame>

                                <!-- Day Shifts -->
                                <VerticalStackLayout IsVisible="{Binding IsExpanded}" 
                                                     BindableLayout.ItemsSource="{Binding Shifts}"
                                                     Padding="0,4,0,0"
                                                     Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:RosterShift">
                                            <Frame Padding="10" 
                                                   CornerRadius="10" 
                                                   HasShadow="False"
                                                   Background="{Binding ., Converter={StaticResource ShiftStatusToGradientConverter}}"
                                                   BorderColor="Transparent">
                                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto, *, Auto">
                                                    
                                                    <!-- Icon (User or R for Relief) -->
                                                    <Frame Grid.RowSpan="3"
                                                           Padding="0"
                                                           HeightRequest="30"
                                                           WidthRequest="30"
                                                           CornerRadius="5"
                                                           BackgroundColor="Transparent"
                                                           BorderColor="White"
                                                           HorizontalOptions="Start"
                                                           VerticalOptions="Center"
                                                           Margin="0,0,10,0">
                                                        <Label x:Name="IconLabel"
                                                               Text="{Binding DisplayIcon}" 
                                                               FontFamily="FontAwesome" 
                                                               FontSize="18" 
                                                               TextColor="White"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center" />
                                                    </Frame>

                                                    <!-- Shift Title: GuardName (License) -->
                                                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                                        <Label x:Name="TitleLabel"
                                                               Text="{Binding DisplayName}" 
                                                               TextColor="White" 
                                                               FontAttributes="Bold" 
                                                               FontSize="17" />
                                                        <Label x:Name="LicenseLabel"
                                                               Text="{Binding DisplayLicense, StringFormat='({0})'}" 
                                                               TextColor="White" 
                                                               FontSize="13" 
                                                               VerticalOptions="Center" 
                                                               Opacity="0.9" />
                                                    </HorizontalStackLayout>

                                                    <!-- Subtitle for Relief Shifts -->
                                                    <HorizontalStackLayout Grid.Row="1" Grid.Column="1" 
                                                                           Spacing="5" 
                                                                           IsVisible="{Binding ReliefGuardId, Converter={StaticResource NotNullToBooleanConverter}}">
                                                        <Label Text="{Binding ReliefReason, StringFormat='[{0}]'}" 
                                                               TextColor="White" 
                                                               FontSize="13" 
                                                               FontAttributes="Bold" />
                                                        <Label Text="{Binding GuardName}" 
                                                               TextColor="White" 
                                                               FontSize="13" 
                                                               Opacity="0.8" />
                                                    </HorizontalStackLayout>
                                                    
                                                    <!-- Time and Duration -->
                                                    <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="8">
                                                        <Label Text="{Binding StartTime}" TextColor="White" FontSize="14" />
                                                        <Label Text="-" TextColor="White" FontSize="14" />
                                                        <Label Text="{Binding EndTime}" TextColor="White" FontSize="14" />
                                                        <Label Text="{Binding DurationHours, StringFormat='({0}h)'}" 
                                                               TextColor="White" 
                                                               FontSize="14" 
                                                               Opacity="0.9" />
                                                    </HorizontalStackLayout>

                                                    <!-- Callsign and Type/Status (Right Aligned) -->
                                                    <Label Grid.Column="2" 
                                                           Text="{Binding CallsignName}" 
                                                           TextColor="White" 
                                                           FontSize="14" 
                                                           FontAttributes="Bold"
                                                           HorizontalOptions="End" />
                                                    
                                                    <VerticalStackLayout Grid.Row="1" Grid.RowSpan="2" Grid.Column="2" 
                                                                         VerticalOptions="Center"
                                                                         HorizontalOptions="End">
                                                        <Label Text="{Binding Status}" 
                                                               TextColor="White" 
                                                               FontSize="13" 
                                                               FontAttributes="Italic"
                                                               HorizontalOptions="End" />
                                                        <Label Text="Relief"
                                                               TextColor="White"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               IsVisible="{Binding ReliefGuardId, Converter={StaticResource NotNullToBooleanConverter}}" 
                                                               HorizontalOptions="End" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                                
                                                <Frame.Triggers>
                                                    <!-- Handle Relief Guard Identity Swap -->
                                                    <DataTrigger TargetType="Frame" Binding="{Binding ReliefGuardId, Converter={StaticResource NotNullToBooleanConverter}}" Value="True">
                                                        <!-- Swapping text is complex in XAML triggers for nested elements, but we can target them by name if they were in a Style, or handle here -->
                                                    </DataTrigger>
                                                </Frame.Triggers>
                                            </Frame>
                                            
                                            <!-- We use a simpler approach for the text swap: Conditional Bindings in Setter/Trigger is limited, 
                                                 so I will use a simple DataTrigger on the Labels within the card. -->
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer / Placeholder -->
        <Label Grid.Row="3" 
               Text="Powered by CityWatch" 
               HorizontalOptions="Center" 
               FontSize="10" 
               TextColor="Gray" />

        <!-- Loading Activity Indicator -->
        <ActivityIndicator x:Name="GlobalLoading"
                         IsRunning="False"
                         Color="{AppThemeBinding Light=#512bd4, Dark=#ac99ea}"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"
                         Grid.RowSpan="4" />
    </Grid>
</ContentPage>
