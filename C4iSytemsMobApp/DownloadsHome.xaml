<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="C4iSytemsMobApp.DownloadsHome"
             Title="Downloads Home">

    <ScrollView>

        <VerticalStackLayout Spacing="20"
                             Padding="10">



            <!-- Row with Back (left) and Home (right) -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="Auto,*,Auto"
                  VerticalOptions="Center"
                  Padding="0,5">

                <!-- Back Button -->
                <Button Text="← Back"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="Blue"
                        FontAttributes="Bold"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        Grid.Column="0" />

                <!-- Title Label -->
                <Label Text="Downloads"
                       FontSize="16"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Grid.Column="1"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <!-- Blue circular Home Button -->
                <Frame Padding="0"
                       HeightRequest="40"
                       WidthRequest="40"
                       CornerRadius="20"
                       BackgroundColor="#007bff"
                       HasShadow="False"
                       HorizontalOptions="End"
                       VerticalOptions="Center"
                       Grid.Column="2">
                    <!-- Home Button -->
                    <ImageButton Source="home.png"
                                 Clicked="OnHomeClicked"
                                 HeightRequest="22"
                                 WidthRequest="22"
                                 BackgroundColor="Transparent"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />
                </Frame>
            </Grid>




            <!-- Main Buttons -->
            <VerticalStackLayout Padding="5"
                                 Spacing="15">

                <Button Text="Company SOPs"
                        Clicked="OnCompanySopClicked"
                        FontAttributes="Bold" />

                <Button Text="Training"
                        Clicked="OnTrainingClicked"
                        FontAttributes="Bold" />

                <Button Text="Forms &amp; Templates"
                        Clicked="OnFormsClicked"
                        FontAttributes="Bold" />

            </VerticalStackLayout>


        </VerticalStackLayout>

    </ScrollView>
</ContentPage>


