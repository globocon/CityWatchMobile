<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>LSRequiresIPhoneOS</key>
		<true />
		<key>UIDeviceFamily</key>
		<array>
			<integer>1</integer>
			<integer>2</integer>
		</array>
		<key>UIRequiredDeviceCapabilities</key>
		<array>
			<string>arm64</string>
		</array>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>XSAppIconAssets</key>
		<string>Assets.xcassets/appicon.appiconset</string>
		<!-- Uncomment for testing in http -->
		<!-- <key>NSAppTransportSecurity</key>
		<dict>
			<key>NSAllowsArbitraryLoads</key>
			<true/>
		</dict>  -->
		<key>NSLocationWhenInUseUsageDescription</key>
		<string>This app uses your location while in use to verify and record on-site security patrol activities, ensuring accuracy and accountability.</string>
		<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
		<string>This app requires continuous location access to monitor and validate security patrol movements in real time, ensuring patrol integrity and enhancing safety compliance.</string>
		<key>UIBackgroundModes</key>
		<array>
			<string>audio</string>
			<string>fetch</string>
			<!-- <string>remote-notification</string> -->
		</array>
		<!-- NFC usage description -->
		<key>NFCReaderUsageDescription</key>
		<string>This app uses NFC to scan designated patrol checkpoints during security operations for the purpose of recording and verifying patrol activities, ensuring adherence to assigned patrol schedules, and maintaining audit and compliance records.</string>
		<!-- Camera usage description -->
		<!-- <key>NSCameraUsageDescription</key>
		<string>This app requires camera access to scan QR codes.</string>  -->
		<!-- Microphone usage description -->
		<!-- <key>NSMicrophoneUsageDescription</key>
		<string>This app requires microphone access for audio and video features.</string> -->
		<key>NSPhotoLibraryUsageDescription</key>
		<string>This app requires access to your photo library to select images for the purpose of uploading proof of on-site security patrol activities.</string>
	</dict>
</plist>
