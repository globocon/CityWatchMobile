<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="C4iSytemsMobApp.Views.SetGuardPinPopup"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Frame Padding="20"
           CornerRadius="0"
           HasShadow="False"
           VerticalOptions="Center"
           HorizontalOptions="Center"
           WidthRequest="280"
           BackgroundColor="{AppThemeBinding Light=White, Dark=Black}">

        <VerticalStackLayout Spacing="15">

            <Label Text="Set HR Document PIN"
                   FontSize="20"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Label Text="Please set a new 4 to 6 digit PIN."
                   FontSize="12"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />

            <Entry x:Name="txtNewPinEntry"
                   Margin="0,5,0,0"
                   Placeholder="New PIN (4-6 digits)"
                   HorizontalOptions="CenterAndExpand"
                   IsPassword="True"
                   Keyboard="Numeric"
                   MaxLength="6"
                   IsEnabled="True" />

            <Entry x:Name="txtConfirmPinEntry"
                   Margin="0,5,0,0"
                   Placeholder="Confirm PIN"
                   HorizontalOptions="CenterAndExpand"
                   IsPassword="True"
                   Keyboard="Numeric"
                   MaxLength="6"
                   IsEnabled="True" />

            <Button Text="Save"
                    Clicked="OnSaveClicked" />

            <Button Text="Cancel"
                    TextColor="Red"
                    Clicked="OnCancelClicked" />

        </VerticalStackLayout>
    </Frame>
</toolkit:Popup>
