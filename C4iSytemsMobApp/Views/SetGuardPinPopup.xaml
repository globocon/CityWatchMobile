<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="C4iSytemsMobApp.Views.SetGuardPinPopup"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Frame Padding="20"
           CornerRadius="5"
           HasShadow="False"
           VerticalOptions="Center"
           HorizontalOptions="Center"
           WidthRequest="340"
           BackgroundColor="{AppThemeBinding Light=White, Dark=Black}">

        <Grid RowDefinitions="Auto, Auto" RowSpacing="20">
            <!-- Header Row -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                <Label Text="Set your PIN for the first time"
                       FontSize="16"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Label Grid.Column="1" 
                       Text="✖" 
                       FontSize="16" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center" 
                       TextColor="Gray">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCancelClicked" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
            <!-- Line Separator -->
            <BoxView Grid.Row="0" VerticalOptions="End" HeightRequest="1" Color="LightGray" Margin="-20,0,-20,-20"/>

            <!-- Content Area -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto" RowSpacing="10" ColumnSpacing="15">
                <Label Grid.Row="0" Grid.Column="0" 
                       Text="Enter New PIN" 
                       VerticalOptions="Center" 
                       TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                
                <Entry Grid.Row="0" Grid.Column="1" 
                       x:Name="txtNewPinEntry"
                       Placeholder=""
                       HeightRequest="35"
                       WidthRequest="130"
                       HorizontalOptions="Start"
                       IsPassword="True"
                       Keyboard="Numeric"
                       MaxLength="6"
                       IsEnabled="True" />
                
                <Label Grid.Row="1" Grid.Column="1" 
                       Text="First-time users are required to enter a custom 4 to 6-digit PIN code to protect their personal information. Please do not share your PIN."
                       FontSize="11"
                       LineBreakMode="WordWrap"
                       TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
                
                <Button Grid.Row="2" Grid.Column="1" 
                        Text="💾 Save PIN" 
                        BackgroundColor="#005B9F"
                        TextColor="White"
                        CornerRadius="4"
                        HeightRequest="35"
                        Padding="10,0"
                        HorizontalOptions="End"
                        Clicked="OnSaveClicked" />
            </Grid>
        </Grid>
    </Frame>
</toolkit:Popup>
